# Copy to .env — restart Metro after changes (pnpm start --clear)
EXPO_PUBLIC_ENV=DEVELOPMENT

# Local dev (pick one for your device):
# Android emulator → host machine API:
EXPO_PUBLIC_DEV_API_URL=http://10.0.2.2:3060
# iOS simulator:
# EXPO_PUBLIC_DEV_API_URL=http://127.0.0.1:3060
# Physical phone on same Wi‑Fi → your PC LAN IP:
# EXPO_PUBLIC_DEV_API_URL=http://192.168.1.5:3060

# Production / shared hosted API (must include /auth/rank-progress on deploy):
EXPO_PUBLIC_PROD_API_URL=https://bewizevent-production.up.railway.app
